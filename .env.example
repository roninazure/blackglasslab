# BlackGlassLab — config template
# Copy to .env and edit:
#   cp .env.example .env

# --- Runtime mode ---
BGL_MODE=paper                  # paper|live
BGL_SOURCE=fake                 # fake|polymarket|kalshi

# --- Database / paths ---
BGL_DB_PATH=memory/runs.sqlite
BGL_LOG_DIR=logs
BGL_SIGNALS_DIR=signals
BGL_REPORT_DIR=reporting

# --- Risk controls (production guardrails) ---
BGL_MIN_EDGE=0.02               # minimum estimated edge required
BGL_MAX_DISAGREEMENT=0.25       # max arbiter disagreement allowed
BGL_MAX_BRIER=0.30              # block if model calibration looks bad
BGL_MAX_DAILY_TRADES=10
BGL_MAX_POSITION_USD=50         # hard cap per trade (paper/live)
BGL_BASE_BET_USD=10             # default sizing base
BGL_STOP_AFTER_LOSS_STREAK=3

# --- Evolution / swarm tuning (optional) ---
BGL_K_OP=3
BGL_K_SK=3
BGL_EVOLVE_INTERVAL=50
BGL_EVOLVE_WINDOW=600
BGL_EVOLVE_MIN_OBS=10
BGL_EVOLVE_KEEP=8
BGL_EVOLVE_SPAWN=8

# --- API keys (leave blank in repo; set in .env only) ---
POLYMARKET_API_KEY=
KALSHI_API_KEY=
KALSHI_API_SECRET=

# --- LLM / Claude (Phase 3) ---
ANTHROPIC_API_KEY=                  # Required for Phase 3 LLM reasoning
BGL_INFER_USE_LLM=1                 # 1=Claude reasoning, 0=baseline heuristic only
BGL_LLM_PROVIDER=anthropic          # anthropic (Claude) only
BGL_LLM_MODEL=claude-haiku-4-5-20251001  # Fast+cheap for infer loop; upgrade to claude-sonnet-4-6 for max edge
